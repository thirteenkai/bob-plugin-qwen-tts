{
    "identifier": "com.qwen.tts.bob.plugin",
    "version": "1.4.0",
    "category": "tts",
    "name": "Qwen TTS",
    "summary": "使用阿里云 Qwen3-TTS-Flash 模型进行语音合成",
    "icon": "microphone",
    "author": "thirteenkai",
    "homepage": "https://github.com/thirteenkai/bob-plugin-qwen-tts",
    "appcast": "https://raw.githubusercontent.com/thirteenkai/bob-plugin-qwen-tts/main/appcast.json",
    "minBobVersion": "1.6.0",
    "options": [
        {
            "identifier": "apiKey",
            "type": "text",
            "title": "API Key",
            "desc": "必填项。请填入 DashScope API Key，可在 https://dashscope.console.aliyun.com/ 申请",
            "textConfig": {
                "type": "secure",
                "height": 40,
                "placeholderText": "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
            }
        },
        {
            "identifier": "region",
            "type": "menu",
            "title": "API 地域",
            "defaultValue": "cn",
            "desc": "选择 API 服务地域，国内用户选择北京，海外用户选择新加坡",
            "menuValues": [
                {
                    "title": "北京 (国内)",
                    "value": "cn"
                },
                {
                    "title": "新加坡 (国际)",
                    "value": "intl"
                }
            ]
        },
        {
            "identifier": "model",
